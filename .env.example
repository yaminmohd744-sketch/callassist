# Copy this file to .env.local for local development
# For production deployments (Railway, Vercel, Netlify etc.) add these as environment variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SERPER_API_KEY=your-serper-key
# Zoom/Meet/Teams need no API keys — live calls are auto-detected (desktop app)
# and captured via system-audio loopback. No OAuth or account linking required.
# VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
