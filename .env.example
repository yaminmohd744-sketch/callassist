# Copy this file to .env.local for local development
# For production deployments (Railway, Vercel, Netlify etc.) add these as environment variables
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SERPER_API_KEY=your-serper-key
VITE_ZOOM_CLIENT_ID=your-zoom-client-id
# Zoom client SECRET is server-side only — set it on the Supabase Edge Function,
# NOT here (anything VITE_-prefixed ships to the browser):
#   supabase secrets set ZOOM_CLIENT_ID=... ZOOM_CLIENT_SECRET=...
# VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx
